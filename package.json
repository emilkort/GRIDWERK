{
  "name": "gridwerk",
  "version": "1.0.0",
  "description": "GRIDWERK - Music Production Dashboard",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node -e \"delete process.env.ELECTRON_RUN_AS_NODE; require('child_process').execSync('electron-vite dev', {stdio:'inherit'})\"",
    "build": "electron-vite build",
    "preview": "node -e \"delete process.env.ELECTRON_RUN_AS_NODE; require('child_process').execSync('electron-vite preview', {stdio:'inherit'})\"",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@tanstack/react-virtual": "^3.13.19",
    "@wavesurfer/react": "^1.0.12",
    "better-sqlite3": "^11.7.0",
    "chokidar": "^3.6.0",
    "cmdk": "^1.1.1",
    "fast-xml-parser": "^5.4.2",
    "music-metadata": "^11.12.1",
    "piscina": "^5.1.4",
    "react-arborist": "^3.4.3",
    "react-error-boundary": "^6.1.1",
    "sonner": "^2.0.7",
    "wavesurfer.js": "^7.12.1",
